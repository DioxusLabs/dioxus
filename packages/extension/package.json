{
  "name": "dioxus",
  "displayName": "Dioxus",
  "description": "Useful tools for working with Dioxus",
  "version": "0.7.3",
  "publisher": "DioxusLabs",
  "private": true,
  "license": "MIT",
  "icon": "dist/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/DioxusLabs/dioxus"
  },
  "engines": {
    "vscode": "^1.86.2"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "main": "./dist/main.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.htmlToDioxusRsx",
        "title": "Dioxus: Convert HTML to RSX"
      },
      {
        "command": "extension.htmlToDioxusComponent",
        "title": "Dioxus: Convert HTML to component"
      },
      {
        "command": "extension.formatRsx",
        "title": "Dioxus: Format selected RSX"
      },
      {
        "command": "extension.formatRsxDocument",
        "title": "Dioxus: Format all RSX in document"
      }
    ],
    "configuration": {
      "properties": {
        "dioxus.formatOnSave": {
          "scope": "resource",
          "type": [
            "string"
          ],
          "default": "followFormatOnSave",
          "enum": [
            "followFormatOnSave",
            "enabled",
            "disabled"
          ],
          "enumItemLabels": [
            "Follow editor setting",
            "Enabled",
            "Disabled"
          ],
          "enumDescriptions": [
            "Only format RSX when saving files if the `editor.formatOnSave` config is enabled",
            "Always format RSX when a Rust file is saved",
            "Never format RSX when a file is saved"
          ],
          "description": "Format RSX when a file is saved"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:release",
    "build:debug": "npm run build:debug/rust && npm run build:debug/ts",
    "build:debug/rust": "wasm-pack build . --dev --no-opt --target web",
    "build:debug/ts": "vite build --mode development",
    "build:release": "npm run build:release/rust && npm run build:release/ts",
    "build:release/rust": "wasm-pack build . --release --target web",
    "build:release/ts": "vite build --mode production",
    "lint": "eslint .",
    "format": "prettier --write .",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/vscode": "^1.86.2",
    "@types/node": "^25.6.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.8",
    "vite-plugin-static-copy": "^4.0.1"
  }
}
